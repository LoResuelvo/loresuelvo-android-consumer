<?xml version="1.0" encoding="utf-8"?>
<!--
  Dev-flavor only. Permits cleartext (plain HTTP) traffic so the app
  can talk to a local backend (emulator 10.0.2.2 or a LAN IP like
  http://192.168.1.33:8080) during development. Staging and prod do
  NOT include this config, so they keep Android's secure-by-default
  HTTPS-only behaviour.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
